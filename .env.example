# Database URL.
#
# LOCAL DEV (SQLite):
DATABASE_URL="file:./db/custom.db"
#
# VERCEL PRODUCTION — switch Prisma provider to "postgresql" in prisma/schema.prisma
# and use a real connection string, e.g. Vercel Postgres / Neon / Supabase:
# DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"
